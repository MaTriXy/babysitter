    <!-- Right: Event Stream -->
    <div class="event-stream-panel">
      <h3>Events (2)</h3>
      <div class="event-list">
        <div class="event-card">
  <div class="event-header">
    <span class="event-icon">&#8594;</span>
    <span class="event-type">EFFECT_REQUESTED</span>
    <span class="event-time">12:00:30</span>
  </div>
  <details><summary>Details</summary><pre>{
  &quot;effectId&quot;: &quot;bp-001&quot;,
  &quot;kind&quot;: &quot;breakpoint&quot;
}</pre></details>
</div>
<div class="event-card">
  <div class="event-header">
    <span class="event-icon">&#9654;</span>
    <span class="event-type">RUN_CREATED</span>
    <span class="event-time">12:00:00</span>
  </div>
