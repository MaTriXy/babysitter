// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`generateWebviewContent - snapshots > generates HTML with multiple task kinds 1`] = `
"<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
