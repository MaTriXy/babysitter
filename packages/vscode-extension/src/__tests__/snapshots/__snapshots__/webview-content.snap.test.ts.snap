  </div>
</div>
<div class="step-card" onclick="selectTask('e3')" data-effect-id="e3">
  <div class="step-number">3</div>
  <div class="step-info">
    <div class="step-title">Skill task</div>
    <div class="step-meta">
      <span class="kind-badge">skill</span>
      <span class="status-icon-requested">&#9679;</span>
