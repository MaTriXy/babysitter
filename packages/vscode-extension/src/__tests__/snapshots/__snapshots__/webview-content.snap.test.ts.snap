  <!-- Main 3-Column Layout -->
  <div class="main-layout">

    <!-- Left: Pipeline -->
    <div class="pipeline-panel">
      <h3>Pipeline</h3>
      <div class="step-card" onclick="selectTask('e1')" data-effect-id="e1">
  <div class="step-number">1</div>
  <div class="step-info">
    <div class="step-title">Node task</div>
    <div class="step-meta">
